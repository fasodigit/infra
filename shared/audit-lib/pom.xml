<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>bf.gov.faso.shared</groupId>
        <artifactId>faso-shared-parent</artifactId>
        <version>1.0.0-SNAPSHOT</version>
        <relativePath>../pom.xml</relativePath>
    </parent>

    <groupId>bf.gov.faso</groupId>
    <artifactId>audit-lib</artifactId>
    <version>1.0.0-SNAPSHOT</version>
    <packaging>jar</packaging>
    <name>FASO Audit Library</name>
    <description>
        Shared audit logging library for FASO DIGITALISATION microservices.
        Provides JPA entity, AOP interceptor, and async writer for append-only audit trail.
        Loi 010-2004 compliance (5 year retention).
    </description>

    <dependencies>
        <!-- spring-boot-autoconfigure is required so AuditAutoConfiguration
             can be picked up by services importing this library. Compile scope
             so consumers automatically pick up the autoconfig classes. -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-autoconfigure</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-data-jpa</artifactId>
            <scope>provided</scope>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-aop</artifactId>
            <scope>provided</scope>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-security</artifactId>
            <scope>provided</scope>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-web</artifactId>
            <scope>provided</scope>
        </dependency>
        <dependency>
            <groupId>io.micrometer</groupId>
            <artifactId>micrometer-core</artifactId>
            <scope>provided</scope>
        </dependency>
        <!-- Tracer: optional. AuditService falls back to null traceId
             if this is missing. Spring Boot starter-actuator already
             pulls it in with the otlp tracing bridge. -->
        <dependency>
            <groupId>io.micrometer</groupId>
            <artifactId>micrometer-tracing</artifactId>
            <scope>provided</scope>
            <optional>true</optional>
        </dependency>
        <!-- Jackson for safe JSON metadata serialization in AuditAspect.
             Provided by spring-boot-starter-web in consumers, declared here
             for compile-time safety in case a consumer omits the web starter. -->
        <dependency>
            <groupId>com.fasterxml.jackson.core</groupId>
            <artifactId>jackson-databind</artifactId>
            <scope>provided</scope>
        </dependency>
    </dependencies>
</project>

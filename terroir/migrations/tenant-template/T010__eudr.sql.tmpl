-- T010__eudr.sql.tmpl
-- EUDR tables (M3) — Module 3 conformité EUDR.
--   eudr_validation : append-only history per parcel × dataset version.
--   dds             : ACID DDS metadata + signature fingerprint.
--   dds_submission  : append-only TRACES NT submission attempts.
-- See ULTRAPLAN §3 + ADR-004.

SET search_path TO {{SCHEMA}};

-- Append-only history of validations.
CREATE TABLE eudr_validation (
  id                       UUID         PRIMARY KEY DEFAULT gen_random_uuid(),
  parcel_id                UUID         NOT NULL,
  status                   VARCHAR(20)  NOT NULL,    -- VALIDATED | REJECTED | ESCALATED
  polygon_hash             VARCHAR(64)  NOT NULL,    -- SHA-256 hex of normalized GeoJSON
  deforestation_overlap_ha DOUBLE PRECISION NOT NULL DEFAULT 0,
  dataset_version          VARCHAR(80)  NOT NULL,
  evidence_url             TEXT,
  hansen_pixels_loss       INTEGER      NOT NULL DEFAULT 0,
  jrc_pixels_loss          INTEGER      NOT NULL DEFAULT 0,
  reason                   TEXT,
  computed_at              TIMESTAMPTZ  NOT NULL DEFAULT now()
);

CREATE INDEX idx_eudr_validation_parcel ON eudr_validation(parcel_id, computed_at DESC);
CREATE INDEX idx_eudr_validation_status ON eudr_validation(status, computed_at DESC);

ALTER TABLE eudr_validation ENABLE ROW LEVEL SECURITY;
CREATE POLICY eudr_validation_app_all ON eudr_validation
  FOR ALL TO terroir_app USING (true) WITH CHECK (true);

-- DDS — Due Diligence Statement metadata + sig.
CREATE TABLE dds (
  id                    UUID         PRIMARY KEY DEFAULT gen_random_uuid(),
  validation_id         UUID         NOT NULL REFERENCES eudr_validation(id),
  parcel_id             UUID         NOT NULL,
  status                VARCHAR(20)  NOT NULL DEFAULT 'draft',
  operator_eori         VARCHAR(40),
  hs_code               VARCHAR(12),
  quantity              DOUBLE PRECISION,
  unit                  VARCHAR(8),
  country_iso2          VARCHAR(2),
  harvest_period        VARCHAR(20),
  payload_json          JSONB        NOT NULL,
  payload_sha256        VARCHAR(64)  NOT NULL,
  signature_fingerprint VARCHAR(80),
  signature_cert_pem    TEXT,
  evidence_url          TEXT,
  created_at            TIMESTAMPTZ  NOT NULL DEFAULT now(),
  updated_at            TIMESTAMPTZ  NOT NULL DEFAULT now(),
  lww_version           BIGINT       NOT NULL DEFAULT 1
);

CREATE INDEX idx_dds_parcel ON dds(parcel_id);
CREATE INDEX idx_dds_status ON dds(status);

ALTER TABLE dds ENABLE ROW LEVEL SECURITY;
CREATE POLICY dds_app_all ON dds
  FOR ALL TO terroir_app USING (true) WITH CHECK (true);

-- TRACES NT submission attempts (append-only).
CREATE TABLE dds_submission (
  id              UUID         PRIMARY KEY DEFAULT gen_random_uuid(),
  dds_id          UUID         NOT NULL REFERENCES dds(id),
  attempt_no      INTEGER      NOT NULL,
  outcome         VARCHAR(20)  NOT NULL,    -- queued | submitted | accepted | rejected | dlq
  traces_nt_ref   VARCHAR(80),
  http_status     INTEGER,
  response_body   TEXT,
  submitted_at    TIMESTAMPTZ  NOT NULL DEFAULT now()
);

CREATE INDEX idx_dds_submission_dds ON dds_submission(dds_id, submitted_at DESC);

ALTER TABLE dds_submission ENABLE ROW LEVEL SECURITY;
CREATE POLICY dds_submission_app_all ON dds_submission
  FOR ALL TO terroir_app USING (true) WITH CHECK (true);

{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "FASO DIGITALISATION Global SLI/SLO — Error Budgets, Uptime, Latency Compliance, Availability Matrix",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    { "title": "KAYA Overview", "url": "/d/faso-kaya-overview-v1", "type": "dashboards" },
    { "title": "ARMAGEDDON Gateway", "url": "/d/faso-armageddon-gateway-v1", "type": "dashboards" },
    { "title": "Auth MS", "url": "/d/faso-auth-ms-v1", "type": "dashboards" },
    { "title": "Poulets Platform", "url": "/d/faso-poulets-platform-v1", "type": "dashboards" },
    { "title": "Notifier MS", "url": "/d/faso-notifier-ms-v1", "type": "dashboards" }
  ],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 600,
      "title": "Error Budget Burndown",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "percentunit", "min": 0, "max": 1, "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 1 },
      "id": 1,
      "options": { "legend": { "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "1 - (sum(rate(armageddon_gateway_requests_total{status=~\"5..\"}[30d])) / sum(rate(armageddon_gateway_requests_total[30d])))",
          "legendFormat": "ARMAGEDDON gateway",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "1 - (sum(rate(auth_login_attempts_total{result=\"failure\"}[30d])) / sum(rate(auth_login_attempts_total[30d])))",
          "legendFormat": "Auth MS",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "1 - (sum(rate(kaya_commands_errors_total[30d])) / sum(rate(kaya_commands_total[30d])))",
          "legendFormat": "KAYA DB",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "1 - (sum(rate(poulets_orders_failed_total[30d])) / sum(rate(poulets_orders_created_total[30d])))",
          "legendFormat": "Poulets Platform",
          "refId": "D"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "1 - (sum(rate(notifier_mail_sent_total{result=\"failure\"}[30d])) / sum(rate(notifier_mail_sent_total[30d])))",
          "legendFormat": "Notifier MS",
          "refId": "E"
        }
      ],
      "title": "Error Budget Burndown par Service (30j rolling)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 601,
      "title": "Uptime & Availability",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.99 },
              { "color": "green", "value": 0.999 }
            ]
          },
          "unit": "percentunit",
          "min": 0.98,
          "max": 1
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 2,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "avg_over_time(up{job=\"armageddon-gateway\"}[30d])",
          "legendFormat": "ARMAGEDDON",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "avg_over_time(up{job=\"auth-ms\"}[30d])",
          "legendFormat": "Auth MS",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "avg_over_time(up{job=\"kaya\"}[30d])",
          "legendFormat": "KAYA",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "avg_over_time(up{job=\"poulets-platform\"}[30d])",
          "legendFormat": "Poulets",
          "refId": "D"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "avg_over_time(up{job=\"notifier-ms\"}[30d])",
          "legendFormat": "Notifier",
          "refId": "E"
        }
      ],
      "title": "Uptime % Rolling 30j",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.1 }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "orientation": "horizontal" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "1 - (sum(rate(armageddon_gateway_request_duration_seconds_bucket{le=\"0.5\"}[30d])) / sum(rate(armageddon_gateway_request_duration_seconds_count[30d])))",
          "legendFormat": "ARMAGEDDON p50<500ms compliance",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "1 - (sum(rate(auth_db_query_duration_seconds_bucket{le=\"0.1\"}[30d])) / sum(rate(auth_db_query_duration_seconds_count[30d])))",
          "legendFormat": "Auth DB p99<100ms compliance",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "1 - (sum(rate(kaya_resp3_latency_seconds_bucket{le=\"0.001\"}[30d])) / sum(rate(kaya_resp3_latency_seconds_count[30d])))",
          "legendFormat": "KAYA p99<1ms compliance",
          "refId": "C"
        }
      ],
      "title": "Latency Objective Compliance",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 602,
      "title": "Availability Matrix",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.995 },
              { "color": "green", "value": 0.999 }
            ]
          },
          "unit": "percentunit",
          "custom": {
            "displayMode": "color-background"
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 19 },
      "id": 4,
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Service", "desc": false }]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "avg_over_time(up[30d])",
          "legendFormat": "{{job}}",
          "refId": "A",
          "instant": true
        }
      ],
      "title": "Availability Matrix — All Services",
      "transformations": [
        { "id": "labelsToFields", "options": { "valueLabel": "job" } },
        { "id": "organize", "options": { "renameByName": { "Time": "Timestamp", "Value": "Availability 30d" } } }
      ],
      "type": "table"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "percentunit", "custom": { "lineWidth": 2, "fillOpacity": 15 } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 27 },
      "id": 5,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (job) (rate(up[30d]))",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "title": "Availability Trends — All Services (30j)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 35 },
      "id": 6,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (service) (increase(slo_error_budget_consumed_total[30d]))",
          "legendFormat": "Budget consommé {{service}}",
          "refId": "A"
        }
      ],
      "title": "Error Budget Consumption Cumulative (30j)",
      "type": "timeseries"
    }
  ],
  "refresh": "5m",
  "schemaVersion": 38,
  "tags": ["sovereignty=faso-digitalisation", "sli", "slo", "global"],
  "templating": { "list": [] },
  "time": { "from": "now-30d", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "FASO SLI/SLO Global",
  "uid": "faso-sli-slo-v1",
  "version": 1
}

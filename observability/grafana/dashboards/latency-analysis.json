          "legendFormat": "p99 latency",
          "refId": "B"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "faso-prometheus-ds" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" } },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": ".*memory.*" }, "properties": [{ "id": "unit", "value": "percentunit" }, { "id": "custom.axisPlacement", "value": "left" }] },
          { "matcher": { "id": "byRegexp", "options": ".*latency.*" }, "properties": [{ "id": "unit", "value": "s" }, { "id": "custom.axisPlacement", "value": "right" }] }
        ]
      },
      "gridPos": { "h": 7, "w": 6, "x": 6, "y": 48 },
      "id": 13,
      "title": "Memory vs Latency Correlation",
      "type": "timeseries",
      "targets": [
        {
          "expr": "1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)",
          "legendFormat": "memory usage",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(otel_span_duration_bucket{service_name=~\"$service\"}[$interval])) by (le))",
          "legendFormat": "p99 latency",
          "refId": "B"
        }
      ]
    },
    {

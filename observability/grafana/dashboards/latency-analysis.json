          "refId": "A"
        },
        {
          "expr": "hikaricp_connections_active{application=~\"$service\"}",
          "legendFormat": "{{ application }} pool active",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(otel_span_duration_bucket{service_name=~\"$service\"}[$interval])) by (le))",
          "legendFormat": "p99 latency",
          "refId": "C"
        }
      ]
    },
    {

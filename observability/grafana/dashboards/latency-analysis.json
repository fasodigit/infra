      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" } },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": ".*GC.*" }, "properties": [{ "id": "unit", "value": "s" }, { "id": "custom.axisPlacement", "value": "left" }] },
          { "matcher": { "id": "byRegexp", "options": ".*latency.*" }, "properties": [{ "id": "unit", "value": "s" }, { "id": "custom.axisPlacement", "value": "right" }] }
        ]

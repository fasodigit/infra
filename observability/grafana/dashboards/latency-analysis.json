    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 55 },
      "id": 106,
      "title": "Network Latency",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "faso-prometheus-ds" },
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 15, "showPoints": "never" } }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 56 },
      "id": 16,
      "title": "Inter-Service Call Latency (from traces)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(traces_service_graph_request_server_seconds_bucket{client=~\"$service\"}[$interval])) by (le, client, server))",
          "legendFormat": "{{ client }} -> {{ server }} p99",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "faso-prometheus-ds" },
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 15, "showPoints": "never" } }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 56 },
      "id": 17,
      "title": "DNS Resolution Time",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(otel_span_duration_bucket{http_target=~\".*\", span_name=~\".*dns.*\"}[$interval])) by (le, service_name))",
          "legendFormat": "{{ service_name }} DNS p99",
          "refId": "A"
        },
        {
          "expr": "probe_dns_lookup_time_seconds",
          "legendFormat": "{{ instance }} DNS probe",
          "refId": "B"
        }
      ]
    },

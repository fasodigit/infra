{
  "__inputs": [],
  "__comment": "SPDX-License-Identifier: AGPL-3.0-or-later — Copyright (C) 2026 FASO DIGITALISATION — SLO multi-service overview dashboard (Sloth generated metrics).",
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "row",
      "title": "Multi-service SLO Overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "stat",
      "title": "SLI error rate (5m) — all services",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "id": 1,
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 0.05,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.001 },
              { "color": "red", "value": 0.01 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "slo:sli_error:ratio_rate5m{sloth_service=~\"$service\"}",
          "legendFormat": "{{sloth_service}} / {{sloth_slo}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Current burn rate (1h) — all services",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "id": 2,
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "orange", "value": 6 },
              { "color": "red", "value": 14.4 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "slo:current_burn_rate:ratio{sloth_service=~\"$service\"}",
          "legendFormat": "{{sloth_service}} / {{sloth_slo}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Error budget remaining (30d)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "id": 3,
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.1 },
              { "color": "yellow", "value": 0.3 },
              { "color": "green", "value": 0.6 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "1 - (slo:sli_error:ratio_rate30d{sloth_service=~\"$service\"} / on(sloth_id, sloth_service, sloth_slo) group_left slo:objective:ratio{sloth_service=~\"$service\"})",
          "legendFormat": "{{sloth_service}} / {{sloth_slo}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "SLI error ratio over time (5m rate)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "id": 4,
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 7 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 15 }
        }
      },
      "targets": [
        {
          "expr": "slo:sli_error:ratio_rate5m{sloth_service=~\"$service\"}",
          "legendFormat": "{{sloth_service}} — {{sloth_slo}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Current burn rate (multi-window)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "id": 5,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter" }
        }
      },
      "targets": [
        {
          "expr": "slo:current_burn_rate:ratio{sloth_service=~\"$service\"}",
          "legendFormat": "{{sloth_service}} — {{sloth_slo}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Period burn rate (30d window)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "id": 6,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineInterpolation": "linear" }
        }
      },
      "targets": [
        {
          "expr": "slo:period_burn_rate:ratio{sloth_service=~\"$service\"}",
          "legendFormat": "{{sloth_service}} — {{sloth_slo}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "table",
      "title": "Active SLO alerts (ALERTS firing)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "id": 7,
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 23 },
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "expr": "ALERTS{alertstate=\"firing\",sloth_service=~\"$service\"}",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "__name__": true, "Time": true, "Value": true },
            "indexByName": {
              "sloth_service": 0,
              "sloth_slo": 1,
              "alertname": 2,
              "severity": 3,
              "sloth_severity": 4,
              "team": 5
            }
          }
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["faso", "slo", "sloth", "reliability"],
  "templating": {
    "list": [
      {
        "current": { "selected": true, "text": "All", "value": ".*" },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(slo:sli_error:ratio_rate5m, sloth_service)",
        "hide": 0,
        "includeAll": true,
        "label": "Service",
        "multi": true,
        "name": "service",
        "options": [],
        "query": {
          "query": "label_values(slo:sli_error:ratio_rate5m, sloth_service)",
          "refId": "Prometheus-service-Variable-Query"
        },
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "FASO — SLO Overview (Sloth)",
  "uid": "faso-slo-overview",
  "version": 1,
  "weekStart": ""
}

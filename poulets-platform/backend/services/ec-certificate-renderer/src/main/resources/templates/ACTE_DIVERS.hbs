{{#> base_etatcivil}}

<!-- Document Title -->
<div class="doc-title-section">
  <div class="doc-type">Acte Administratif</div>
  <div class="doc-subtitle">Document Administratif &mdash; Document Officiel</div>
</div>

<!-- Reference Bar -->
<div class="reference-bar">
  <div class="ref-item">
    <div class="ref-label">R&eacute;f&eacute;rence</div>
    <div class="ref-value">{{reference}}</div>
  </div>
  <div class="ref-item">
    <div class="ref-label">N&deg; Acte</div>
    <div class="ref-value">{{numeroActe}}</div>
  </div>
  <div class="ref-item">
    <div class="ref-label">Date d'&Eacute;mission</div>
    <div class="ref-value">{{dateEmission}}</div>
  </div>
</div>

<!-- Status Badge -->
<div class="status-section">
  <div class="status-badge valide">
    <span class="status-icon">&#10003;</span>
    DOCUMENT OFFICIEL
  </div>
</div>

<!-- Main Content Grid -->
<div class="content-grid">
  <!-- Left: Info Cards -->
  <div>
    <!-- Subject -->
    <div class="info-card">
      <div class="info-card-header">
        <span>&#128196;</span> Objet
      </div>
      <div class="info-card-body">
        {{#if typeActe}}
        <div class="info-row">
          <span class="info-label">Type</span>
          <span class="info-value">{{typeActe}}</span>
        </div>
        {{/if}}
        {{#if objet}}
        <div class="info-row">
          <span class="info-label">Objet</span>
          <span class="info-value">{{objet}}</span>
        </div>
        {{/if}}
        {{#if description}}
        <div class="info-row">
          <span class="info-label">Description</span>
          <span class="info-value">{{description}}</span>
        </div>
        {{/if}}
      </div>
    </div>

    <!-- Beneficiary -->
    <div class="info-card">
      <div class="info-card-header">
        <span>&#128100;</span> B&eacute;n&eacute;ficiaire
      </div>
      <div class="info-card-body">
        <div class="info-row">
          <span class="info-label">Nom</span>
          <span class="info-value highlight">{{nom}}</span>
        </div>
        <div class="info-row">
          <span class="info-label">Pr&eacute;noms</span>
          <span class="info-value highlight">{{prenoms}}</span>
        </div>
        {{#if dateNaissance}}
        <div class="info-row">
          <span class="info-label">Date de naissance</span>
          <span class="info-value">{{dateNaissance}}</span>
        </div>
        {{/if}}
      </div>
    </div>

    <!-- Additional Details (dynamic metadata) -->
    {{#if metadata}}
    <div class="info-card">
      <div class="info-card-header accent-blue">
        <span>&#128203;</span> D&eacute;tails
      </div>
      <div class="info-card-body">
        {{#each metadata}}
        <div class="info-row">
          <span class="info-label">{{@key}}</span>
          <span class="info-value">{{this}}</span>
        </div>
        {{/each}}
      </div>
    </div>
    {{/if}}

  </div>

  <!-- Right: QR Code -->
  <div class="qr-section">
    <div class="qr-container">
      <div class="qr-title">Code QR de V&eacute;rification</div>
      {{#if qrCodeDataUrl}}
      <img class="qr-code-img" src="{{qrCodeDataUrl}}" alt="QR Code HMAC" />
      {{/if}}
      <div class="qr-verified">
        <span>&#10003;</span> HMAC V&Eacute;RIFI&Eacute;
      </div>
      <div class="qr-instructions">
        Scannez pour v&eacute;rifier sur<br>
        <strong>verify.etatcivil.bf</strong>
      </div>
    </div>
    <!-- Compact Crypto Hash -->
    <div class="crypto-hash-compact">
      <div class="crypto-title">Empreinte Cryptographique</div>
      {{#if hashSha256}}
      <div class="crypto-item">
        <div class="crypto-label">SHA-256</div>
        <div class="crypto-value">{{hashSha256}}</div>
      </div>
      {{/if}}
      {{#if verificationToken}}
      <div class="crypto-item">
        <div class="crypto-label">Token</div>
        <div class="crypto-value">{{verificationToken}}</div>
      </div>
      {{/if}}
      {{#if verificationUrl}}
      <div class="crypto-item">
        <div class="crypto-label">V&eacute;rification</div>
        <div class="crypto-value">{{verificationUrl}}</div>
      </div>
      {{/if}}
    </div>
  </div>
</div>

{{/base_etatcivil}}

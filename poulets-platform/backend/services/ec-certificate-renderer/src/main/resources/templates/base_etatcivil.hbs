<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{documentTitle}} — ETAT CIVIL</title>
  <style>
    /* ================================================================
       ETAT CIVIL — Government-Grade Certificate Template
       Adapted from SOGESY design system for Burkina Faso
       Optimized for Chromium Headless PDF Generation (A4)
       ================================================================ */

    /* Fonts are inlined as data:URI by AssetInliner at startup — no external fetch needed */

    :root {
      --bf-green: #006B3F;
      --bf-green-dark: #004D2C;
      --bf-green-light: #E8F5EE;
      --bf-red: #CE1126;
      --bf-red-light: #FFF0F2;
      --bf-yellow: #FCD116;
      --bf-yellow-light: #FFFDE6;
      --gold: #B8860B;
      --gold-light: #F5ECD7;
      --ink: #1A1A2E;
      --ink-soft: #4A4A5A;
      --ink-muted: #8A8A9A;
      --paper: #FEFDFB;
      --border-fine: #D4D0C8;
      --security-blue: #1B4F72;
    }

    @page {
      size: A4;
      margin: 0;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      width: 210mm;
      min-height: 297mm;
      margin: 0 auto;
      background: var(--paper);
      font-family: 'Noto Sans', sans-serif;
      color: var(--ink);
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    /* -- Security Background Pattern -- */
    .page-container {
      position: relative;
      width: 210mm;
      min-height: 297mm;
      padding: 6mm;
      overflow: hidden;
    }

    .page-container::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0; bottom: 0;
      background:
        repeating-linear-gradient(
          45deg,
          transparent,
          transparent 2mm,
          rgba(0, 107, 63, 0.015) 2mm,
          rgba(0, 107, 63, 0.015) 2.3mm
        ),
        repeating-linear-gradient(
          -45deg,
          transparent,
          transparent 2mm,
          rgba(206, 17, 38, 0.008) 2mm,
          rgba(206, 17, 38, 0.008) 2.3mm
        );
      pointer-events: none;
      z-index: 0;
    }

    /* -- Watermark -- */
    .watermark {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%) rotate(-35deg);
      font-family: 'Source Serif 4', serif;
      font-size: 72pt;
      font-weight: 700;
      color: rgba(0, 107, 63, 0.035);
      letter-spacing: 12px;
      white-space: nowrap;
      pointer-events: none;
      z-index: 0;
      user-select: none;
    }

    .content-wrapper {
      position: relative;
      z-index: 1;
    }

    /* -- Outer Decorative Border -- */
    .document-frame {
      border: 2.5px solid var(--bf-green);
      padding: 3mm;
      position: relative;
    }

    .document-frame::before {
      content: '';
      position: absolute;
      top: 2mm; left: 2mm; right: 2mm; bottom: 2mm;
      border: 0.8px solid var(--bf-green);
      opacity: 0.4;
      pointer-events: none;
    }

    .inner-frame {
      border: 0.5px solid var(--border-fine);
      padding: 5mm 7mm;
    }

    /* -- Header Band (National Colors) -- */
    .national-band {
      display: flex;
      height: 4px;
      margin-bottom: 3mm;
      border-radius: 1px;
      overflow: hidden;
    }
    .national-band .green  { flex: 1; background: var(--bf-green); }
    .national-band .red    { flex: 1; background: var(--bf-red); }
    .national-band .yellow { flex: 1; background: var(--bf-yellow); }

    /* -- Header Section -- */
    .header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      margin-bottom: 2mm;
    }

    .header-left {
      flex: 1;
    }

    .country-label {
      font-family: 'Source Serif 4', serif;
      font-size: 8pt;
      font-weight: 600;
      color: var(--bf-green-dark);
      text-transform: uppercase;
      letter-spacing: 2px;
      margin-bottom: 0.5mm;
    }

    .ministry-label {
      font-size: 7pt;
      color: var(--ink-soft);
      letter-spacing: 0.5px;
    }

    .header-center {
      flex: 0 0 auto;
      text-align: center;
      padding: 0 6mm;
    }

    /* -- Coat of Arms Placeholder -- */
    .coat-of-arms {
      width: 18mm;
      height: 18mm;
      margin: 0 auto 1mm;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--bf-green-light), var(--gold-light));
      border: 1.5px solid var(--gold);
      position: relative;
    }

    .coat-of-arms .star {
      font-size: 16pt;
      color: var(--bf-green);
    }

    .header-right {
      flex: 1;
      text-align: right;
    }

    .platform-badge {
      display: inline-flex;
      align-items: center;
      gap: 2mm;
      background: linear-gradient(135deg, var(--bf-green-dark), var(--bf-green));
      color: white;
      padding: 2mm 4mm;
      border-radius: 2px;
      font-size: 8pt;
      font-weight: 600;
      letter-spacing: 1.5px;
    }

    .platform-badge .version {
      font-size: 6pt;
      opacity: 0.75;
      font-weight: 400;
    }

    /* -- Document Title -- */
    .doc-title-section {
      text-align: center;
      margin: 2mm 0 3mm;
      padding: 2mm 0;
      border-top: 1px solid var(--border-fine);
      border-bottom: 1px solid var(--border-fine);
      position: relative;
    }

    .doc-title-section::before,
    .doc-title-section::after {
      content: '\25C6';
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      color: var(--gold);
      font-size: 7pt;
    }
    .doc-title-section::before { left: 8mm; }
    .doc-title-section::after  { right: 8mm; }

    .doc-type {
      font-family: 'Source Serif 4', serif;
      font-size: 15pt;
      font-weight: 700;
      color: var(--bf-green-dark);
      letter-spacing: 3px;
      text-transform: uppercase;
      margin-bottom: 1mm;
    }

    .doc-subtitle {
      font-size: 8pt;
      color: var(--ink-muted);
      letter-spacing: 2px;
      text-transform: uppercase;
    }

    /* -- Reference Bar -- */
    .reference-bar {
      display: flex;
      justify-content: center;
      gap: 8mm;
      margin-bottom: 3mm;
      padding: 2mm 0;
      background: var(--bf-green-light);
      border-radius: 2px;
    }

    .ref-item {
      text-align: center;
    }

    .ref-label {
      font-size: 6pt;
      color: var(--ink-muted);
      text-transform: uppercase;
      letter-spacing: 1.5px;
      margin-bottom: 0.5mm;
    }

    .ref-value {
      font-family: 'JetBrains Mono', monospace;
      font-size: 9pt;
      font-weight: 600;
      color: var(--bf-green-dark);
      letter-spacing: 0.5px;
    }

    /* -- Status Badge -- */
    .status-section {
      text-align: center;
      margin-bottom: 6mm;
    }

    .status-badge {
      display: inline-flex;
      align-items: center;
      gap: 2mm;
      padding: 2.5mm 8mm;
      border-radius: 2px;
      font-size: 10pt;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
    }

    .status-badge.valide {
      background: linear-gradient(135deg, #D4EDDA, #C3E6CB);
      color: #155724;
      border: 1px solid #A3D9B1;
    }

    .status-badge.en-cours {
      background: linear-gradient(135deg, var(--bf-yellow-light), #FEF3C7);
      color: #78350F;
      border: 1px solid var(--bf-yellow);
    }

    .status-badge.rejete {
      background: linear-gradient(135deg, #F8D7DA, #F5C6CB);
      color: #721C24;
      border: 1px solid #F1B0B7;
    }

    .status-badge.expire {
      background: linear-gradient(135deg, #FEF3C7, #FDE68A);
      color: #92400E;
      border: 1px solid #F59E0B;
    }

    .status-badge .status-icon {
      font-size: 12pt;
    }

    /* -- Main Content Grid -- */
    .content-grid {
      display: grid;
      grid-template-columns: 1fr 52mm;
      gap: 4mm;
      margin-bottom: 3mm;
    }

    /* -- Info Card -- */
    .info-card {
      border: 1px solid var(--border-fine);
      border-radius: 3px;
      overflow: hidden;
      margin-bottom: 2mm;
    }

    .info-card:last-child {
      margin-bottom: 0;
    }

    .info-card-header {
      background: linear-gradient(135deg, var(--bf-green), var(--bf-green-dark));
      color: white;
      padding: 1.5mm 3mm;
      font-size: 7pt;
      font-weight: 600;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      display: flex;
      align-items: center;
      gap: 2mm;
    }

    .info-card-header.accent-red {
      background: linear-gradient(135deg, var(--bf-red), #A00D1E);
    }

    .info-card-header.accent-gold {
      background: linear-gradient(135deg, var(--gold), #8B6914);
    }

    .info-card-header.accent-blue {
      background: linear-gradient(135deg, var(--security-blue), #14395D);
    }

    .info-card-body {
      padding: 2mm 3mm;
    }

    .info-row {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      padding: 1mm 0;
      border-bottom: 0.5px dashed var(--border-fine);
    }

    .info-row:last-child {
      border-bottom: none;
    }

    .info-label {
      font-size: 7pt;
      color: var(--ink-muted);
      text-transform: uppercase;
      letter-spacing: 0.8px;
      flex: 0 0 auto;
    }

    .info-value {
      font-size: 8pt;
      font-weight: 600;
      color: var(--ink);
      text-align: right;
    }

    .info-value.highlight {
      color: var(--bf-green-dark);
      font-size: 9pt;
    }

    .info-value.mono {
      font-family: 'JetBrains Mono', monospace;
      font-size: 7pt;
    }

    /* -- QR + Crypto Stacked (no gap, seamless) -- */
    .qr-section {
      display: flex;
      flex-direction: column;
      gap: 0;
    }

    .qr-container {
      border: 1px solid var(--border-fine);
      border-radius: 3px 3px 0 0;
      padding: 3mm;
      background: white;
      text-align: center;
      width: 100%;
    }

    .qr-title {
      font-size: 6pt;
      color: var(--ink-muted);
      text-transform: uppercase;
      letter-spacing: 1.5px;
      margin-bottom: 2mm;
    }

    .qr-code-img {
      width: 34mm;
      height: 34mm;
      margin: 0 auto 2mm;
      display: block;
      image-rendering: pixelated;
    }

    .qr-verified {
      display: inline-flex;
      align-items: center;
      gap: 1mm;
      font-size: 6pt;
      color: #155724;
      background: #D4EDDA;
      padding: 1mm 2mm;
      border-radius: 2px;
      font-weight: 600;
      margin-bottom: 1mm;
    }

    .qr-instructions {
      font-size: 5.5pt;
      color: var(--ink-muted);
      line-height: 1.4;
      margin-top: 1mm;
    }

    /* -- Compact Crypto Hash (below QR) -- */
    .crypto-hash-compact {
      border: 1px solid var(--border-fine);
      border-top: none;
      border-radius: 0 0 3px 3px;
      padding: 2mm 3mm;
      background: linear-gradient(135deg, #F8F9FA, #EEF0F2);
      border-left: 2px solid var(--security-blue);
      margin-top: 0;
      width: 100%;
    }

    .crypto-hash-compact .crypto-title {
      font-size: 5.5pt;
      font-weight: 600;
      color: var(--security-blue);
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 1.5mm;
    }

    .crypto-hash-compact .crypto-item {
      margin-bottom: 1mm;
    }

    .crypto-hash-compact .crypto-label {
      font-size: 5pt;
      color: var(--ink-muted);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .crypto-hash-compact .crypto-value {
      font-family: 'JetBrains Mono', monospace;
      font-size: 5pt;
      color: var(--security-blue);
      word-break: break-all;
      line-height: 1.3;
    }

    /* -- Timeline Section -- */
    .timeline-section {
      margin-bottom: 5mm;
    }

    .timeline-header {
      font-size: 7pt;
      font-weight: 600;
      color: var(--ink-soft);
      text-transform: uppercase;
      letter-spacing: 1.5px;
      margin-bottom: 3mm;
    }

    .timeline {
      display: flex;
      align-items: center;
      gap: 0;
      padding: 0 4mm;
    }

    .timeline-step {
      display: flex;
      flex-direction: column;
      align-items: center;
      flex: 1;
      position: relative;
    }

    .timeline-dot {
      width: 8mm;
      height: 8mm;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 7pt;
      font-weight: 700;
      z-index: 1;
    }

    .timeline-dot.completed {
      background: var(--bf-green);
      color: white;
    }

    .timeline-dot.current {
      background: var(--bf-yellow);
      color: var(--ink);
      box-shadow: 0 0 0 2px rgba(252, 209, 22, 0.3);
    }

    .timeline-dot.pending {
      background: #E9ECEF;
      color: var(--ink-muted);
    }

    .timeline-label {
      font-size: 5.5pt;
      color: var(--ink-muted);
      margin-top: 1.5mm;
      text-align: center;
      letter-spacing: 0.3px;
    }

    .timeline-connector {
      flex: 1;
      height: 2px;
      margin-top: -4mm;
    }

    .timeline-connector.done {
      background: var(--bf-green);
    }

    .timeline-connector.pending {
      background: #E9ECEF;
    }

    /* -- Security Hash Section -- */
    .security-section {
      margin-bottom: 5mm;
      padding: 4mm;
      background: linear-gradient(135deg, #F8F9FA, #EEF0F2);
      border: 1px solid var(--border-fine);
      border-radius: 3px;
      border-left: 3px solid var(--security-blue);
    }

    .security-title {
      font-size: 7pt;
      font-weight: 600;
      color: var(--security-blue);
      text-transform: uppercase;
      letter-spacing: 1.5px;
      margin-bottom: 3mm;
      display: flex;
      align-items: center;
      gap: 2mm;
    }

    .security-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3mm;
    }

    .sec-item {
      padding: 2mm;
    }

    .sec-label {
      font-size: 6pt;
      color: var(--ink-muted);
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 1mm;
    }

    .sec-value {
      font-family: 'JetBrains Mono', monospace;
      font-size: 7pt;
      color: var(--ink);
      word-break: break-all;
      line-height: 1.4;
    }

    .sec-value.hash {
      font-size: 6.5pt;
      color: var(--security-blue);
      background: rgba(27, 79, 114, 0.05);
      padding: 1.5mm;
      border-radius: 2px;
    }

    /* -- Compliance Footer -- */
    .compliance-section {
      margin-bottom: 4mm;
      padding: 3mm 4mm;
      border: 1px solid var(--border-fine);
      border-radius: 3px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .compliance-item {
      text-align: center;
      flex: 1;
    }

    .compliance-icon {
      font-size: 12pt;
      margin-bottom: 1mm;
    }

    .compliance-label {
      font-size: 6pt;
      color: var(--ink-muted);
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .compliance-value {
      font-size: 7.5pt;
      font-weight: 600;
      color: var(--ink);
    }

    /* -- Legal Footer -- */
    .legal-footer {
      text-align: center;
      padding-top: 2mm;
      border-top: 1px solid var(--border-fine);
    }

    .legal-text {
      font-size: 6pt;
      color: var(--ink-muted);
      line-height: 1.4;
      max-width: 140mm;
      margin: 0 auto 1mm;
    }

    .footer-brand {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 2mm;
      margin-top: 2mm;
    }

    .footer-brand span {
      font-size: 6pt;
      color: var(--ink-muted);
      letter-spacing: 0.5px;
    }

    /* -- National Band Bottom -- */
    .national-band-bottom {
      display: flex;
      height: 3px;
      margin-top: 2mm;
      border-radius: 1px;
      overflow: hidden;
    }
    .national-band-bottom .green  { flex: 1; background: var(--bf-green); }
    .national-band-bottom .red    { flex: 1; background: var(--bf-red); }
    .national-band-bottom .yellow { flex: 1; background: var(--bf-yellow); }
  </style>
</head>
<body>
  <div class="page-container">
    <!-- Watermark -->
    <div class="watermark">ETAT CIVIL</div>

    <div class="content-wrapper">
      <div class="document-frame">
        <div class="inner-frame">

          <!-- National Colors Band -->
          <div class="national-band">
            <div class="green"></div>
            <div class="red"></div>
            <div class="yellow"></div>
          </div>

          <!-- Header -->
          <div class="header">
            <div class="header-left">
              <div class="country-label">Burkina Faso</div>
              <div class="ministry-label">{{#if ministere}}{{ministere}}{{else}}Minist&egrave;re de l'Administration Territoriale,<br>de la D&eacute;centralisation et de la S&eacute;curit&eacute;{{/if}}</div>
            </div>
            <div class="header-center">
              <div class="coat-of-arms">
                <span class="star">&#9733;</span>
              </div>
            </div>
            <div class="header-right">
              <div class="platform-badge">
                ETAT CIVIL <span class="version">v1.0</span>
              </div>
              <div style="font-size: 6.5pt; color: var(--ink-muted); margin-top: 1.5mm; letter-spacing: 0.5px;">
                Plateforme Num&eacute;rique<br>
                d'&Eacute;tat Civil
              </div>
            </div>
          </div>

          <!-- Document-specific content injected here -->
          {{> @partial-block}}

          <!-- Legal Footer -->
          <div class="legal-footer">
            <div class="legal-text">
              Document g&eacute;n&eacute;r&eacute; &eacute;lectroniquement &mdash; Plateforme Num&eacute;rique d'&Eacute;tat Civil du Burkina Faso.
              Original num&eacute;rique ayant valeur probante. Falsification passible de poursuites p&eacute;nales.
            </div>
            <div class="footer-brand">
              <span>G&eacute;n&eacute;r&eacute; le {{dateGeneration}} UTC</span>
              <span>&bull;</span>
              <span>ETAT CIVIL v1.0 &mdash; Burkina Faso</span>
            </div>
          </div>

          <!-- National Colors Band Bottom -->
          <div class="national-band-bottom">
            <div class="green"></div>
            <div class="red"></div>
            <div class="yellow"></div>
          </div>

        </div>
      </div>
    </div>
  </div>
</body>
</html>

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8"/>
  <title>[ALTMISSION] Mise à jour — {{repo_full_name}}</title>
  <style>
    body { font-family: Arial, sans-serif; background:#f5f5f5; margin:0; padding:0; }
    .container { max-width:680px; margin:32px auto; background:#fff; border-radius:8px; box-shadow:0 2px 8px rgba(0,0,0,.1); overflow:hidden; }
    .header { background:#1b5e20; color:#fff; padding:24px 32px; }
    .header h1 { margin:0; font-size:20px; }
    .badge { background:rgba(255,255,255,.2); border-radius:4px; padding:2px 8px; font-size:12px; font-weight:600; }
    .body { padding:24px 32px; }
    .commit-list { border-left:3px solid #1b5e20; padding-left:16px; margin:16px 0; }
    .commit-item { margin-bottom:10px; }
    .btn { background:#1b5e20; color:#fff; padding:10px 28px; border-radius:4px; text-decoration:none; font-size:14px; display:inline-block; margin-top:16px; }
    .footer { background:#f5f5f5; padding:14px 32px; font-size:12px; color:#999; border-top:1px solid #eee; }
  </style>
</head>
<body>
<div class="container">
  <div class="header">
    <h1>🎯 Mise à jour AltMission — Missions</h1>
    <p style="margin:4px 0 0;font-size:13px;opacity:.8">{{repo_full_name}} · FASO DIGITALISATION</p>
  </div>
  <div class="body">
    <p style="font-size:13px;color:#555;">
      <strong>Repo :</strong> <a href="{{repo_url}}" style="color:#1b5e20">{{repo_full_name}}</a> &nbsp;|&nbsp;
      <strong>Branche :</strong> <span class="badge">{{branch}}</span> &nbsp;|&nbsp;
      <strong>{{commit_count}} commit(s)</strong> par <strong>{{author_login}}</strong>
    </p>
    <div class="commit-list">
      {{#each commits}}
      <div class="commit-item">
        <span style="font-family:monospace;font-size:12px;color:#1b5e20;">{{shortSha this.id}}</span>
        <span style="font-size:14px;"> — {{truncate this.message len=100}}</span>
        <div style="font-size:12px;color:#888;">{{this.author.name}} &lt;{{this.author.email}}&gt;</div>
      </div>
      {{/each}}
    </div>
    <a href="{{compare_url}}" class="btn">Voir le diff</a>
  </div>
  <div class="footer">FASO DIGITALISATION — notifier-ms · {{rendered_at}}</div>
</div>
</body>
</html>

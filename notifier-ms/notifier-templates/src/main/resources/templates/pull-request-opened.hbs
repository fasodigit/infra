<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8"/>
  <title>[PR] Nouvelle Pull Request — {{repo_full_name}}</title>
  <style>
    body { font-family: Arial, sans-serif; background:#f5f5f5; margin:0; padding:0; }
    .container { max-width:680px; margin:32px auto; background:#fff; border-radius:8px; box-shadow:0 2px 8px rgba(0,0,0,.1); overflow:hidden; }
    .header { background:#0d47a1; color:#fff; padding:24px 32px; }
    .header h1 { margin:0; font-size:20px; }
    .pr-card { border:1px solid #e0e0e0; border-radius:6px; padding:16px 20px; margin:16px 0; }
    .pr-title { font-size:18px; font-weight:600; color:#0d47a1; margin-bottom:8px; }
    .pr-meta { font-size:13px; color:#555; display:flex; gap:16px; flex-wrap:wrap; }
    .branch-pill { background:#e3f2fd; color:#0d47a1; border-radius:12px; padding:2px 10px; font-size:12px; }
    .pr-body { font-size:13px; color:#444; margin:12px 0; border-top:1px solid #eee; padding-top:12px; white-space:pre-wrap; }
    .btn { background:#0d47a1; color:#fff; padding:10px 28px; border-radius:4px; text-decoration:none; font-size:14px; display:inline-block; margin-top:16px; }
    .footer { background:#f5f5f5; padding:14px 32px; font-size:12px; color:#999; border-top:1px solid #eee; }
  </style>
</head>
<body>
<div class="container">
  <div class="header">
    <h1>🔀 Nouvelle Pull Request ouverte</h1>
    <p style="margin:4px 0 0;font-size:13px;opacity:.8">{{repo_full_name}} · FASO DIGITALISATION</p>
  </div>
  <div style="padding:24px 32px;">
    <div class="pr-card">
      <div class="pr-title">#{{pr_number}} — {{pr_title}}</div>
      <div class="pr-meta">
        <span>Auteur : <strong>{{pr_author}}</strong></span>
        <span><span class="branch-pill">{{pr_head_ref}}</span> → <span class="branch-pill">{{pr_base_ref}}</span></span>
        <span>État : <strong>{{pr_state}}</strong></span>
      </div>
      {{#if pr_body}}
      <div class="pr-body">{{truncate pr_body len=500}}</div>
      {{/if}}
    </div>
    <a href="{{pr_url}}" class="btn">Consulter la Pull Request</a>
  </div>
  <div class="footer">FASO DIGITALISATION — notifier-ms · {{rendered_at}}</div>
</div>
</body>
</html>

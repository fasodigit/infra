<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>[INFRA] Push — {{repo_full_name}}</title>
  <style>
    body { font-family: 'Segoe UI', Arial, sans-serif; background:#f5f5f5; margin:0; padding:0; }
    .container { max-width:680px; margin:32px auto; background:#fff; border-radius:8px; overflow:hidden; box-shadow:0 2px 8px rgba(0,0,0,.1); }
    .header { background:#1a237e; color:#fff; padding:24px 32px; }
    .header h1 { margin:0; font-size:20px; }
    .header .subtitle { font-size:13px; opacity:.8; margin-top:4px; }
    .badge { display:inline-block; background:#e8f5e9; color:#2e7d32; border-radius:4px; padding:2px 8px; font-size:12px; font-weight:600; }
    .body { padding:24px 32px; }
    .meta-row { display:flex; gap:24px; margin-bottom:16px; font-size:13px; color:#555; }
    .commit-list { border-left:3px solid #1a237e; padding-left:16px; margin:16px 0; }
    .commit-item { margin-bottom:12px; }
    .commit-sha { font-family:monospace; font-size:12px; color:#1565c0; background:#e3f2fd; border-radius:3px; padding:1px 5px; }
    .commit-msg { font-size:14px; color:#222; margin:4px 0; }
    .commit-author { font-size:12px; color:#777; }
    .file-changes { font-size:12px; margin-top:4px; }
    .file-added { color:#2e7d32; }
    .file-modified { color:#f57f17; }
    .file-removed { color:#c62828; }
    .cta { display:block; margin:24px 0; text-align:center; }
    .btn { background:#1a237e; color:#fff; padding:10px 28px; border-radius:4px; text-decoration:none; font-size:14px; }
    .footer { background:#f5f5f5; padding:16px 32px; font-size:12px; color:#999; border-top:1px solid #eee; }
    .footer a { color:#1565c0; text-decoration:none; }
  </style>
</head>
<body>
<div class="container">
  <div class="header">
    <h1>🏗 Nouveau push — Infrastructure</h1>
    <div class="subtitle">FASO DIGITALISATION · DevOps Notification</div>
  </div>
  <div class="body">
    <div class="meta-row">
      <span><strong>Repo :</strong> <a href="{{repo_url}}" style="color:#1565c0">{{repo_full_name}}</a></span>
      <span><strong>Branche :</strong> <span class="badge">{{branch}}</span></span>
      <span><strong>Commits :</strong> {{commit_count}}</span>
    </div>
    {{#if sender_login}}
    <div class="meta-row">
      {{#if avatar_url}}<img src="{{avatar_url}}" width="24" height="24" style="border-radius:50%;vertical-align:middle;margin-right:6px"/>{{/if}}
      <span><strong>Auteur :</strong> <a href="{{author_url}}" style="color:#1565c0">{{author_login}}</a></span>
    </div>
    {{/if}}

    <h3 style="color:#1a237e;margin:20px 0 12px">Commits</h3>
    <div class="commit-list">
      {{#each commits}}
      <div class="commit-item">
        <a href="{{this.url}}" class="commit-sha">{{shortSha this.id}}</a>
        <div class="commit-msg">{{truncate this.message len=120}}</div>
        <div class="commit-author">par {{this.author.name}} &lt;{{this.author.email}}&gt;</div>
        {{#if this.added}}
        <div class="file-changes">
          <span class="file-added">+{{this.added.length}} ajouté(s)</span>
          {{#if this.modified}}<span class="file-modified"> · ~{{this.modified.length}} modifié(s)</span>{{/if}}
          {{#if this.removed}}<span class="file-removed"> · -{{this.removed.length}} supprimé(s)</span>{{/if}}
        </div>
        {{/if}}
      </div>
      {{/each}}
    </div>

    <div class="cta">
      <a href="{{compare_url}}" class="btn">Voir le diff complet</a>
    </div>
  </div>
  <div class="footer">
    Notifié par <strong>FASO DIGITALISATION — notifier-ms</strong> · {{rendered_at}}<br/>
    <a href="{{repo_url}}">{{repo_full_name}}</a>
  </div>
</div>
</body>
</html>

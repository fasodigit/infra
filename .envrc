# FASO DIGITALISATION — direnv configuration
# Redirects build caches to / partition to prevent /home saturation.
# Cached on /var/tmp (partition /, 153 GB) since 2026-04-18.

export CARGO_TARGET_DIR="/var/tmp/faso-cache/cargo-target"
export PLAYWRIGHT_BROWSERS_PATH="/var/tmp/faso-cache/playwright"
export npm_config_cache="/var/tmp/faso-cache/npm"

# Rust toolchain — pin via rust-toolchain.toml if present
# Java — ~/.m2 already symlinked to /var/tmp/faso-cache/m2
